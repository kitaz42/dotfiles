
# --- Шрифты ---
font_family      JetBrainsMono Nerd Font
font_size        11.0
bold_font        auto
italic_font      auto

# --- Прозрачность и Окно ---
confirm_os_window_close    0
window_padding_width      10
# Убираем стандартные рамки (Hyprland сам нарисует красивые)
hide_window_decorations   yes

# --- Курсор ---
cursor_shape               beam
cursor_blink_interval      0.5

# --- Цветовая схема (Tokyo Night) ---
# background            #1a1b26
foreground            #a9b1d6
selection_background  #33467c
selection_foreground  #c0caf5

# Цвета для команд
color0 #414868
color1 #f7768e
color2 #73daca
color3 #e0af68
color4 #7aa2f7
color5 #bb9af7
color6 #7dcfff
color7 #c0caf5
background_opacity         0.7
